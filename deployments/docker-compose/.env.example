# 复制为 .env 后，供本地开发时读取（可选）

# PostgreSQL（与 docker-compose.infra.yml 中一致）
POSTGRES_USER=pim
POSTGRES_PASSWORD=pim
POSTGRES_DB=pim
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_MAX_OPEN_CONNS=80
POSTGRES_MAX_IDLE_CONNS=40
POSTGRES_CONN_MAX_LIFETIME_SEC=300
POSTGRES_CONN_MAX_IDLE_TIME_SEC=120

# 连接串格式（Go 里用）
# DATABASE_URL=postgres://pim:pim@localhost:5432/pim?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BROKERS=localhost:9092

# MinIO (对象存储)
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=pimminio
MINIO_SECRET_KEY=pimminiopass
MINIO_BUCKET=pim-files
MINIO_USE_SSL=false

# Log/ES
ELASTICSEARCH_URL=http://localhost:9200
LOG_SERVICE_HTTP_URL=http://localhost:9016
FILE_SERVICE_HTTP_URL=http://localhost:9006
# 服务监听地址（仅当你单独运行某个服务时需要；`go run ./cmd/all` 会覆盖这些端口）
AUTH_HTTP_ADDR=:9000
AUTH_GRPC_ADDR=:9005
USER_HTTP_ADDR=:9001
USER_GRPC_ADDR=:9011
LOG_TOPIC=log-topic
LOG_INFO_SAMPLE_PCT=100

# Auth
JWT_SECRET=pim-dev-secret

# -------- 多实例端口与路由）--------
USER1_HTTP_ADDR=:9001
USER1_GRPC_ADDR=:9011
USER2_HTTP_ADDR=:9101
USER2_GRPC_ADDR=:9111

AUTH1_HTTP_ADDR=:9000
AUTH1_GRPC_ADDR=:9005
AUTH2_HTTP_ADDR=:9100
AUTH2_GRPC_ADDR=:9105

CONVERSATION1_HTTP_ADDR=:9003
CONVERSATION1_GRPC_ADDR=:9013
CONVERSATION2_HTTP_ADDR=:9103
CONVERSATION2_GRPC_ADDR=:9113
CONVERSATION3_HTTP_ADDR=:9203
CONVERSATION3_GRPC_ADDR=:9213

GROUP1_HTTP_ADDR=:9004
GROUP1_GRPC_ADDR=:9014
GROUP2_HTTP_ADDR=:9104
GROUP2_GRPC_ADDR=:9114
GROUP3_HTTP_ADDR=:9204
GROUP3_GRPC_ADDR=:9214

GATEWAY1_HTTP_ADDR=:8080
GATEWAY1_PUSH_GRPC_ADDR=:8090
GATEWAY1_NODE_ID=gateway-1
GATEWAY2_HTTP_ADDR=:8180
GATEWAY2_PUSH_GRPC_ADDR=:8190
GATEWAY2_NODE_ID=gateway-2

GATEWAY_PUSH_GRPC_TARGETS=gateway-1=localhost:8090,gateway-2=localhost:8190

GATEWAY1_AUTH_SERVICE_GRPC_TARGET=localhost:9005
GATEWAY1_USER_SERVICE_GRPC_TARGET=localhost:9011
GATEWAY1_FRIEND_SERVICE_GRPC_TARGET=localhost:9012
GATEWAY1_CONVERSATION_SERVICE_GRPC_TARGET=localhost:9013
GATEWAY1_GROUP_SERVICE_GRPC_TARGET=localhost:9014

GATEWAY2_AUTH_SERVICE_GRPC_TARGET=localhost:9105
GATEWAY2_USER_SERVICE_GRPC_TARGET=localhost:9111
GATEWAY2_FRIEND_SERVICE_GRPC_TARGET=localhost:9012
GATEWAY2_CONVERSATION_SERVICE_GRPC_TARGET=localhost:9213
GATEWAY2_GROUP_SERVICE_GRPC_TARGET=localhost:9214
