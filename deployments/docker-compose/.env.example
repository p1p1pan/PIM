# 复制为 .env 后，供本地开发时读取（可选）
# 阶段 0 仅需确认能连接，Go 服务阶段 1 再引用

# PostgreSQL（与 docker-compose.infra.yml 中一致）
POSTGRES_USER=pim
POSTGRES_PASSWORD=pim
POSTGRES_DB=pim
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 连接串格式（Go 里用）
# DATABASE_URL=postgres://pim:pim@localhost:5432/pim?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BROKERS=localhost:9092

# MinIO (对象存储)
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=pimminio
MINIO_SECRET_KEY=pimminiopass
MINIO_BUCKET=pim-files
MINIO_USE_SSL=false

# Log/ES
ELASTICSEARCH_URL=http://localhost:9200
LOG_SERVICE_HTTP_URL=http://localhost:9016
FILE_SERVICE_HTTP_URL=http://localhost:9006
LOG_TOPIC=log-topic
LOG_INFO_SAMPLE_PCT=100

# Auth
JWT_SECRET=pim-dev-secret
