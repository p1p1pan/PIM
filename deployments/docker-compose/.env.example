# 复制为 .env 后，供本地开发时读取（可选）

# PostgreSQL（与 docker-compose.infra.yml 中一致）
POSTGRES_USER=pim
POSTGRES_PASSWORD=pim
POSTGRES_DB=pim
POSTGRES_HOST=localhost
# 与 infra compose 映射一致（默认 55432:5432）
POSTGRES_PORT=55432
POSTGRES_MAX_OPEN_CONNS=80
POSTGRES_MAX_IDLE_CONNS=40
POSTGRES_CONN_MAX_LIFETIME_SEC=300
POSTGRES_CONN_MAX_IDLE_TIME_SEC=120

# 连接串格式（Go 里用）
# DATABASE_URL=postgres://pim:pim@localhost:5432/pim?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BROKERS=localhost:9092

# MinIO (对象存储)
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=pimminio
MINIO_SECRET_KEY=pimminiopass
MINIO_BUCKET=pim-files
MINIO_USE_SSL=false

# Log/ES
ELASTICSEARCH_URL=http://localhost:9200
LOG_SERVICE_HTTP_URL=http://localhost:26016
FILE_SERVICE_HTTP_URL=http://localhost:26006
# 服务监听地址（仅当你单独运行某个服务时需要；`go run ./cmd/all` 会覆盖这些端口）
AUTH_HTTP_ADDR=:26000
AUTH_GRPC_ADDR=:26005
USER_HTTP_ADDR=:26001
USER_GRPC_ADDR=:26011
FRIEND_HTTP_ADDR=:26002
FRIEND_GRPC_ADDR=:26012
FILE_HTTP_ADDR=:26006
FILE_GRPC_ADDR=:26015
LOG_HTTP_ADDR=:26016
LOG_TOPIC=log-topic
LOG_INFO_SAMPLE_PCT=100
GATEWAY_LOGIN_MAX_INFLIGHT=0
USER_PASSWORD_BCRYPT_COST=10

# Auth
JWT_SECRET=pim-dev-secret

# -------- 多实例端口与路由）--------
USER1_HTTP_ADDR=:26001
USER1_GRPC_ADDR=:26011
USER2_HTTP_ADDR=:26101
USER2_GRPC_ADDR=:26111

AUTH1_HTTP_ADDR=:26000
AUTH1_GRPC_ADDR=:26005
AUTH2_HTTP_ADDR=:26100
AUTH2_GRPC_ADDR=:26105

FRIEND1_HTTP_ADDR=:26002
FRIEND1_GRPC_ADDR=:26012

CONVERSATION1_HTTP_ADDR=:26003
CONVERSATION1_GRPC_ADDR=:26013
CONVERSATION2_HTTP_ADDR=:26103
CONVERSATION2_GRPC_ADDR=:26113
CONVERSATION3_HTTP_ADDR=:26203
CONVERSATION3_GRPC_ADDR=:26213

GROUP1_HTTP_ADDR=:26004
GROUP1_GRPC_ADDR=:26014
GROUP2_HTTP_ADDR=:26104
GROUP2_GRPC_ADDR=:26114
GROUP3_HTTP_ADDR=:26204
GROUP3_GRPC_ADDR=:26214

FILE1_HTTP_ADDR=:26006
FILE1_GRPC_ADDR=:26015
LOG1_HTTP_ADDR=:26016

GATEWAY1_HTTP_ADDR=:26080
GATEWAY1_PUSH_GRPC_ADDR=:26090
GATEWAY1_NODE_ID=gateway-1
GATEWAY2_HTTP_ADDR=:26180
GATEWAY2_PUSH_GRPC_ADDR=:26190
GATEWAY2_NODE_ID=gateway-2

# etcd：gRPC 服务注册与发现（须 `docker compose -f deployments/docker-compose/docker-compose.infra.yml` 已启动 etcd）
ETCD_ENDPOINTS=127.0.0.1:2379
ETCD_KEY_PREFIX=/pim/v1
ETCD_LEASE_TTL_SEC=10
